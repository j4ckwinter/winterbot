---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['panel', className]}>
  <slot />
</div>

<style>
  .panel {
    position: relative;
    background: var(--color-surface);
    border: 4px solid var(--color-border);
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 6px 6px 0px var(--color-shadow);
    /* CRITICAL: overflow must NOT be hidden — it clips the ::before inner highlight ring */
  }

  .panel::before {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    right: 2px;
    bottom: 2px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 6px; /* 8px - 2px */
    pointer-events: none;
  }
</style>
