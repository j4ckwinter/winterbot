---
import Panel from '../Panel.astro';

const hero = {
  name: '[Your Name]',
  class: 'Frontend Engineer',
  level: 12,
  maxLevel: 20,
  region: 'Remote / United States',
};
const levelPct = Math.round((hero.level / hero.maxLevel) * 100);
---

<section id="hero" aria-labelledby="hero-heading">
  <div class="hero-layout">
    <!-- Left: headline + tagline (outside the trainer card) -->
    <div class="hero-intro">
      <h1 id="hero-heading" class="hero-heading">Crafting Interfaces<br />Worth Exploring</h1>
      <p class="hero-tagline">Frontend engineer specializing in fast, accessible, memorable experiences.</p>
      <div class="hero-cta">
        <a href="#projects" class="cta-btn">View Projects</a>
        <a href="#contact" class="cta-btn cta-btn--secondary">Contact</a>
      </div>
    </div>
    <!-- Right: trainer card (Panel-wrapped) -->
    <Panel class="trainer-card">
      <!-- Portrait placeholder: square with initials or styled box -->
      <div class="portrait-placeholder" aria-hidden="true">
        <span class="portrait-initials">?</span>
      </div>
      <!-- Stats column -->
      <div class="trainer-stats">
        <div class="stat">
          <span class="stat-label">NAME</span>
          <span class="stat-value">{hero.name}</span>
        </div>
        <div class="stat">
          <span class="stat-label">CLASS</span>
          <span class="stat-value">{hero.class}</span>
        </div>
        <div class="stat level-stat">
          <span class="stat-label">LEVEL</span>
          <div
            class="pixel-bar"
            role="progressbar"
            aria-valuenow={hero.level}
            aria-valuemin={0}
            aria-valuemax={hero.maxLevel}
            aria-label={`Level ${hero.level} of ${hero.maxLevel}`}
          >
            <div class="pixel-fill" style={`width: ${levelPct}%`}></div>
          </div>
          <span class="level-number">LVL {hero.level}</span>
        </div>
        <div class="stat">
          <span class="stat-label">REGION</span>
          <span class="stat-value">{hero.region}</span>
        </div>
      </div>
    </Panel>
  </div>
</section>

<style>
  section#hero {
    padding-block: 4rem;
  }

  .hero-heading {
    font-family: 'DotGothic16', monospace;
    color: var(--color-surface);
    font-size: 2.5rem;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .hero-layout {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 3rem;
  }

  .hero-intro {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-tagline {
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-surface);
    font-size: 1rem;
    opacity: 0.85;
    margin: 0;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .cta-btn {
    display: inline-block;
    font-family: 'DotGothic16', monospace;
    font-size: 0.85rem;
    padding: 0.5rem 1.5rem;
    border: 2px solid var(--color-border);
    background: transparent;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .cta-btn:hover,
  .cta-btn:focus-visible {
    opacity: 0.8;
  }

  .cta-btn:focus-visible {
    outline: 3px solid var(--color-accent-primary);
    outline-offset: 3px;
  }

  .cta-btn--secondary {
    color: var(--color-surface);
    border-color: var(--color-surface);
    opacity: 0.7;
  }

  .cta-btn--secondary:hover,
  .cta-btn--secondary:focus-visible {
    opacity: 1;
  }

  /* Trainer card layout inside Panel */
  :global(.trainer-card) {
    flex-shrink: 0;
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .portrait-placeholder {
    width: 120px;
    height: 120px;
    border: 4px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-world);
    flex-shrink: 0;
  }

  .portrait-initials {
    font-family: 'DotGothic16', monospace;
    color: var(--color-surface);
    font-size: 2rem;
  }

  .trainer-stats {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-label {
    font-family: 'DotGothic16', monospace;
    font-size: 0.65rem;
    color: var(--color-accent-secondary);
    letter-spacing: 0.1em;
  }

  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .level-stat {
    gap: 0.3rem;
  }

  .pixel-bar {
    width: 120px;
    height: 12px;
    border: 2px solid var(--color-border);
    background: var(--color-world);
    overflow: hidden;
  }

  .pixel-fill {
    height: 100%;
    background: var(--color-accent-primary);
  }

  .level-number {
    font-family: 'DotGothic16', monospace;
    font-size: 0.7rem;
    color: var(--color-accent-primary);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .hero-layout {
      flex-direction: column;
    }

    :global(.trainer-card) {
      flex-direction: column;
    }
  }
</style>
