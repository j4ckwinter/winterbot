---
const entries = [
  {
    company: 'KTO',
    role: 'Senior Frontend Developer',
    dateRange: '2025 – Present',
    isCurrent: true,
    achievements: [
      'Led the frontend takeover of the Sportsbook platform, replacing Kambi’s hosted UI with a fully custom React-based, Typescript solution.',
      'Migrated legacy Javascript code to a TypeScript monorepo with shared packages, improving scalability and developer efficiency.',
      'Delivered real-time, data-driven UI features using event-based integrations, enabling live updates for odds, betslip, and open bets.',
      'Performance improvements through targeted optimisations (rendering strategy, preloader behaviour, DOM stability), reducing perceived load time.',
      'Reduced unnecessary re-renders by refactoring complex UI structures, improving runtime performance across high-traffic components.',
    ],
  },
  {
    company: 'GeoGaming Group',
    role: 'Senior Angular Developer',
    dateRange: '2023 – 2025',
    isCurrent: false,
    achievements: [
      'Led performance optimisations, reducing load times by 30% and improving overall UX.',
      'Developed and modernised frontend architecture, introducing efficient bundling strategies and lazy loading to optimise performance.',
      'Enhanced unit test coverage from 25% to 75%, implementing Jest and Cypress for end-to-end and integration testing.',
      'Designed and developed dynamic, real-time UI components using RxJS, WebSockets, and REST APIs for seamless data streaming.',
      'Mentored junior developers, conducting code reviews and promoting best practices in frontendengineering.'
    ],
  },
  {
    company: 'Smartstream Technologies',
    role: 'Senior Software Engineer',
    dateRange: '2017 – 2022',
    isCurrent: false,
    achievements: [
      'Led the development of a greenfield Angular front-end project, replacing a legacy system and enabling the acquisition of two high-profile deals.',
      'Designed and developed in-house tools using React and Node.js to streamline internal workflows,improving team efficiency.',
      'Conducted interviews for candidates across junior to senior developer roles.',
      'Developed a machine learning model prototype for improving transaction forecast accuracy, resulting in reliable predictions for banking clients.',
      'Collaborated closely with DevOps teams to resolve critical system issues, ensuring 24/7 reliability byproviding on-call support.',
    ],
  },
];
---

<section id="experience" aria-labelledby="experience-heading">
  <h2 id="experience-heading" class="section-heading">Quest Log</h2>
  <ol class="timeline">
    {entries.map((entry) => (
      <li class:list={['timeline-entry', 'exp-entry', { 'is-current': entry.isCurrent }]}>
        <span class="marker" aria-hidden="true">{entry.isCurrent ? '◆' : '◇'}</span>
        <div class="entry-content">
          <div class="entry-header">
            <h3 class="entry-role">{entry.role}</h3>
            {entry.isCurrent && <span class="active-badge" aria-label="Current role">ACTIVE</span>}
          </div>
          <p class="entry-company">{entry.company}</p>
          <p class="entry-date">{entry.dateRange}</p>
          <ul class="achievements">
            {entry.achievements.map((a) => <li>{a}</li>)}
          </ul>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  section {
    padding-block: 4rem;
  }

  .section-heading {
    font-family: 'DotGothic16', monospace;
    color: var(--color-surface);
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.8rem;
    top: 1rem;
    bottom: 1rem;
    border-left: 2px dashed var(--color-border);
  }

  .timeline-entry {
    position: relative;
    padding-left: 3rem;
    margin-bottom: 2.5rem;
    display: flex;
    gap: 0;
  }

  .marker {
    position: absolute;
    left: 0.5rem;
    top: 0.25rem;
    font-size: 1.2rem;
    color: var(--color-accent-secondary);
  }

  .timeline-entry.is-current .marker {
    color: var(--color-accent-primary);
  }

  .entry-content {
    flex: 1;
    background: var(--color-surface);
    border: 4px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 4px 4px 0 var(--color-shadow);
  }

  .timeline-entry.is-current .entry-content {
    border-color: var(--color-accent-primary);
  }

  .entry-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .entry-role {
    font-family: 'DotGothic16', monospace;
    font-size: 1rem;
    color: var(--color-text);
    margin: 0;
  }

  .active-badge {
    font-family: 'DotGothic16', monospace;
    font-size: 0.65rem;
    background: var(--color-accent-primary);
    color: var(--color-surface);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.1em;
  }

  .entry-company,
  .entry-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-accent-secondary);
    margin: 0.1rem 0;
  }

  .achievements {
    list-style: none;
    padding: 0;
    margin-top: 0.75rem;
  }

  .achievements li {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    padding-left: 1rem;
    position: relative;
  }

  .achievements li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent-secondary);
  }

  @media (max-width: 640px) {
    section {
      padding-block: 2rem;
    }

    .timeline-entry {
    margin-bottom: 0;
  }
  }
</style>

<script>
  const expEntries = document.querySelectorAll('.exp-entry');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  expEntries.forEach((el) => revealObserver.observe(el));
</script>
