---
const entries = [
  {
    company: 'Acme Technologies',
    role: 'Senior Frontend Engineer',
    dateRange: '2022 – Present',
    isCurrent: true,
    achievements: [
      'Rebuilt the core dashboard with React and TypeScript, reducing load time by 40%',
      'Led migration from REST to GraphQL for all product data fetching',
      'Established component library used across 4 product teams',
      'Mentored 3 junior engineers through structured code review cycles',
    ],
  },
  {
    company: 'Startup Co.',
    role: 'Frontend Engineer',
    dateRange: '2019 – 2022',
    isCurrent: false,
    achievements: [
      'Built customer-facing checkout flow handling $2M+ monthly transactions',
      'Implemented A/B testing framework integrated with feature flags',
      'Reduced bundle size by 35% through code splitting and lazy loading',
    ],
  },
  {
    company: 'Agency Works',
    role: 'Junior Developer',
    dateRange: '2017 – 2019',
    isCurrent: false,
    achievements: [
      'Delivered 12 client sites using HTML, CSS, and vanilla JavaScript',
      "Introduced CSS custom properties across the team's component library",
    ],
  },
];
---

<section id="experience" aria-labelledby="experience-heading">
  <h2 id="experience-heading" class="section-heading">Quest Log</h2>
  <ol class="timeline">
    {entries.map((entry) => (
      <li class:list={['timeline-entry', 'exp-entry', { 'is-current': entry.isCurrent }]}>
        <span class="marker" aria-hidden="true">{entry.isCurrent ? '◆' : '◇'}</span>
        <div class="entry-content">
          <div class="entry-header">
            <h3 class="entry-role">{entry.role}</h3>
            {entry.isCurrent && <span class="active-badge" aria-label="Current role">ACTIVE</span>}
          </div>
          <p class="entry-company">{entry.company}</p>
          <p class="entry-date">{entry.dateRange}</p>
          <ul class="achievements">
            {entry.achievements.map((a) => <li>{a}</li>)}
          </ul>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  section {
    padding-block: 4rem;
  }

  .section-heading {
    font-family: 'DotGothic16', monospace;
    color: var(--color-surface);
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 1rem;
    top: 2rem;
    bottom: 2rem;
    border-left: 2px dashed var(--color-border);
  }

  .timeline-entry {
    position: relative;
    padding-left: 3rem;
    margin-bottom: 2.5rem;
    display: flex;
    gap: 0;
  }

  .marker {
    position: absolute;
    left: 0.5rem;
    top: 0.25rem;
    font-size: 1.2rem;
    color: var(--color-accent-secondary);
  }

  .timeline-entry.is-current .marker {
    color: var(--color-accent-primary);
  }

  .entry-content {
    flex: 1;
    background: var(--color-surface);
    border: 4px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 4px 4px 0 var(--color-shadow);
  }

  .timeline-entry.is-current .entry-content {
    border-color: var(--color-accent-primary);
  }

  .entry-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .entry-role {
    font-family: 'DotGothic16', monospace;
    font-size: 1rem;
    color: var(--color-text);
    margin: 0;
  }

  .active-badge {
    font-family: 'DotGothic16', monospace;
    font-size: 0.65rem;
    background: var(--color-accent-primary);
    color: var(--color-surface);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.1em;
  }

  .entry-company,
  .entry-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-accent-secondary);
    margin: 0.1rem 0;
  }

  .achievements {
    list-style: none;
    padding: 0;
    margin-top: 0.75rem;
  }

  .achievements li {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    padding-left: 1rem;
    position: relative;
  }

  .achievements li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent-secondary);
  }
</style>

<script>
  const expEntries = document.querySelectorAll('.exp-entry');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  expEntries.forEach((el) => revealObserver.observe(el));
</script>
