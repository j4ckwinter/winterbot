---
import Panel from '../Panel.astro';
---

<section id="contact" aria-labelledby="contact-heading">
  <h2 id="contact-heading" class="section-heading">Rest Area / Save Point</h2>
  <p class="section-sub">You've made it this far. Take a breather.</p>
  <Panel class="contact-panel">
    <p class="contact-prompt">Want to collaborate, hire, or just say hello?</p>
    <ul class="contact-links" aria-label="Contact links">
      <li>
        <a href="mailto:jackwinter.10@gmail.com" class="contact-link">
          <span class="link-icon" aria-hidden="true">✉</span>
          <span>jackwinter.10@gmail.com</span>
        </a>
      </li>
      <li>
        <a href="https://github.com/j4ckwinter" class="contact-link" target="_blank" rel="noopener noreferrer">
          <span class="link-icon" aria-hidden="true">◆</span>
          <span>github.com/j4ckwinter</span>
        </a>
      </li>
      <li>
        <a href="https://linkedin.com/in/jack-winter-409a09a4" class="contact-link" target="_blank" rel="noopener noreferrer">
          <span class="link-icon" aria-hidden="true">◆</span>
          <span>linkedin.com/in/jack-winter-409a09a4</span>
        </a>
      </li>
    </ul>
  </Panel>
</section>

<style>
  section {
    padding-block: 4rem;
  }
  .section-heading {
    font-family: 'DotGothic16', monospace;
    color: var(--color-surface);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .section-sub {
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-surface);
    opacity: 0.75;
    font-size: 0.85rem;
    margin-bottom: 2rem;
  }
  /* Contact panel: wider padding, softer border, warm accent — distinct from default Panel */
  :global(.contact-panel.panel) {
    padding: 3rem;
    border-color: var(--color-accent-primary);
    box-shadow: 8px 8px 0px var(--color-accent-primary);
  }
  .contact-prompt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }
  .contact-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--color-accent-primary);
    text-decoration: none;
  }
  .contact-link:hover {
    text-decoration: underline;
  }
  .contact-link:focus-visible {
    outline: 3px solid var(--color-accent-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .link-icon {
    color: var(--color-accent-secondary);
    font-size: 1rem;
  }
</style>
