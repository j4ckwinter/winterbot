---
import ProjectCard from '../ui/ProjectCard.astro';

const projects = [
  {
    dexNumber: '#001',
    name: 'WinterBot Portfolio',
    description: 'A GBA-inspired interactive portfolio site built with Astro and Tailwind v4. Fire/Leaf dual theme system.',
    tags: ['Astro', 'TypeScript', 'Tailwind', 'Playwright'],
    githubUrl: 'https://github.com/j4ckwinter/winterbot',
    liveUrl: 'https://winterbot.vercel.app',
  },
  {
    dexNumber: '#002',
    name: 'FPL Radar API',
    description: 'A backend engine for Fantasy Premier League (FPL) mini-league analysis. It answers “what should I do this week?”.',
    tags: ['NodeJS', 'TypeScript', 'Fastify', 'Vite', 'Prisma', 'PostgreSQL', 'BullMQ'],
    githubUrl: 'https://github.com/j4ckwinter/fpl-radar',
  },
  {
    dexNumber: '#003',
    name: 'FPL Radar UI',
    description: 'A web app for viewing and analysing your Fantasy Premier League (FPL) mini-league. It provides a comprehensive overview of your team, including player performance, fixture difficulty, and gameweek trends.',
    tags: ['React', 'Tailwind', 'Storybook', 'CVA', 'CSLX', 'pnpm', 'Vite', 'Playwright'],
    githubUrl: 'https://github.com/j4ckwinter/fpl-radar-ui',
  },
];
---

<section id="projects" aria-labelledby="projects-heading">
  <h2 id="projects-heading" class="section-heading">Pokédex</h2>
  <div class="projects-grid">
    {projects.map((p) => <ProjectCard {...p} />)}
  </div>
</section>

<style>
  .section-heading {
    font-family: 'DotGothic16', monospace;
    color: var(--color-surface);
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
