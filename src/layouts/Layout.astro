---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import JourneyNav from '../components/nav/JourneyNav.astro';
import DialogueSystem from '../components/dialogue/DialogueSystem.tsx';

interface Props {
  title?: string;
}

const { title = 'WinterBot Portfolio' } = Astro.props;
---

<html lang="en" data-theme="fire">
  <head>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const theme = (saved === 'fire' || saved === 'leaf') ? saved : 'fire';
        document.documentElement.setAttribute('data-theme', theme);
        if (!saved) localStorage.setItem('theme', 'fire');
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DotGothic16&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <JourneyNav />
    <header>
      <ThemeToggle client:load />
    </header>
    <main>
      <slot />
    </main>
    <DialogueSystem client:load />
  </body>
</html>

<style>
  header {
    margin-left: 8rem;
    padding: 0 1.5rem;
  }

  main {
    margin-left: 8rem;
    padding: 0 1.5rem;
  }

  @media (max-width: 640px) {
    header {
      margin-left: 0;
      padding: 0 1rem;
    }

    main {
      margin-left: 0;
      padding: 0 1rem;
    }
  }
</style>
